# Copy to .env and fill in. Never commit the real .env file.

# --- Backend / Flask ---
APP_ENV=development
SECRET_KEY=change-me
JWT_SECRET_KEY=change-me

# --- Database ---
# Host is "db" once the backend itself runs inside docker-compose (M1 later step).
# Until then, running Flask directly on your machine, use "localhost" instead.
DATABASE_URL=postgresql://techdigest:techdigest@db:5432/techdigest
TEST_DATABASE_URL=postgresql://techdigest:techdigest@db:5432/techdigest_test

# --- Redis (Celery broker + cache) ---
REDIS_URL=redis://redis:6379/0

# --- AI provider (choose one; see docs/architecture.md) ---
AI_PROVIDER=ollama
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.2
# HUGGINGFACE_API_KEY=
# OPENROUTER_API_KEY=

# --- Frontend ---
VITE_API_BASE_URL=http://localhost:5000/api
